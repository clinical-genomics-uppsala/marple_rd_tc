# Reference workflow structure is documented in workflow/manifest.yaml.

include: "rules/common_references.smk"


report: "report/workflow.rst"


rule all:
    input:
        unpack(compile_output_list),


# Reusable hydra module for reference asset generation.
module references:
    snakefile:
        get_module_snakefile(config, "hydra-genetics/references", path="workflow/Snakefile", tag=config["modules"]["references"])
    config:
        config


use rule * from references as references_*
